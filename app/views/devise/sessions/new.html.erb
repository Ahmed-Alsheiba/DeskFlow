<div class="flex items-center justify-center min-h-screen bg-gradient-to-b from-slate-900 via-slate-900 to-slate-800 px-4 py-12 text-slate-100">
  <div class="max-w-md w-full bg-slate-800 border-slate-700 border border-l-4 text-slate-200 border-l-blue-400 rounded-lg p-6 shadow-sm">
    <h1 class="text-2xl font-bold mb-6 text-slate-100">Sign In</h1>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-4">
        <%= f.label :email, class: "block text-sm font-medium mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-100" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, class: "block text-sm font-medium mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-100" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="mb-4 flex items-center">
          <%= f.check_box :remember_me, class: "rounded" %>
          <%= f.label :remember_me, class: "ml-2 text-sm text-slate-200" %>
        </div>
      <% end %>

      <button type="submit" class="w-full bg-blue-500 text-white px-4 py-2 rounded font-medium">Sign In</button>
    <% end %>

    <div class="mt-4 text-center text-sm">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
