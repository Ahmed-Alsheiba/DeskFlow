<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "DeskFlow" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gradient-to-b from-slate-900 via-slate-900 to-slate-800 text-slate-100" data-turbo-prefetch="false">
    

    <div class="relative z-10">
    <header class="border-b border-slate-900 bg-white/10 backdrop-blur sticky top-0 z-50">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <%= link_to root_path, class: "flex items-center gap-3" do %>
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-blue-600 text-lg font-bold text-white shadow-lg shadow-blue-500/20">
            D
          </div>

          <div>
            <h1 class="text-lg text-slate-100 font-semibold tracking-tight">DeskFlow</h1>
            <p class="text-xs text-slate-200">Hotel Operations Ticketing</p>
          </div>
        <% end %>

        <nav class="hidden items-center gap-8 md:flex">
          <a href="#features" class="text-sm font-medium text-slate-100 transition hover:text-blue-600">
            Features
          </a>

          <a href="#workflow" class="text-sm font-medium text-slate-100 transition hover:text-blue-600">
            Workflow
          </a>

          <a href="#dashboard" class="text-sm font-medium text-slate-100 transition hover:text-blue-600">
            Dashboard
          </a>

          <%= link_to "Tickets", tickets_path, class: "text-sm font-medium text-slate-100 transition hover:text-blue-600" %>
        </nav>

        <div class="flex items-center gap-3">
          <% if user_signed_in? %>
            <% if current_user.admin? || current_user.manager? || preview_mode? %>
              <%= link_to "Admin Dashboard", admin_dashboard_path, class: "hidden text-sm text-slate-200 lg:block hover:underline" %>
            <% end %>
            <% if preview_mode? %>
              <span class="hidden lg:inline-flex items-center rounded-lg bg-amber-500/15 px-3 py-1.5 text-xs font-semibold text-amber-300 ring-1 ring-amber-400/30">Preview Mode</span>
              <%= button_to "Exit Preview", destroy_user_session_path, method: :delete, class: "rounded-xl border border-slate-300 px-5 py-2 text-sm font-bold text-slate-200 transition hover:bg-slate-200 hover:text-black" %>
            <% else %>
              <%= link_to edit_user_registration_path, class: "hidden text-sm text-slate-200 lg:block hover:underline" do %>
                <strong><%= user_display_name(current_user) %></strong> (<%= current_user.role.capitalize %>)
              <% end %>
              <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "rounded-xl border border-slate-300 px-5 py-2 text-sm font-bold text-slate-200 transition hover:bg-slate-200 hover:text-black" %>
            <% end %>
          <% else %>
            <%= button_to "▶ Live Demo", preview_path, class: "hidden rounded-xl border border-emerald-400/60 bg-emerald-500/10 px-5 py-2 text-sm font-semibold text-emerald-200 transition hover:bg-emerald-500/20 md:block", form_class: "inline-block" %>
            <%= link_to "Login", new_user_session_path, class: "hidden rounded-xl border border-slate-300 px-5 py-2 text-sm font-medium text-slate-200 transition hover:bg-slate-200 hover:text-black md:block" %>
            <%= link_to "New? Sign Up", new_user_registration_path, class: "rounded-xl bg-blue-600 px-5 py-2 text-sm font-semibold text-white shadow-lg shadow-blue-500/30 transition hover:bg-blue-700" %>
          <% end %>
        </div>
      </div>
    </header>

    <% if preview_mode? %>
      <div class="sticky top-[73px] z-40 border-b border-slate-600 bg-slate-700/95 text-slate-200 backdrop-blur">
        <div class="mx-auto flex max-w-7xl flex-col items-center justify-center gap-2 px-6 py-2.5 text-center text-sm sm:flex-row">
          <span class="inline-flex items-center gap-2">
            <span aria-hidden="true">🔒</span>
            <span><strong class="font-semibold text-white">Preview mode</strong> — you're exploring a read-only demo. Changes are disabled.</span>
          </span>
          <%= button_to "Sign up to get full access", preview_path(to: "signup"), method: :delete, class: "rounded-lg bg-blue-600 px-3 py-1 text-xs font-semibold text-white transition hover:bg-blue-700", form_class: "inline-block" %>
        </div>
      </div>
    <% end %>

    <div class="fixed top-20 left-1/2 transform -translate-x-1/2 z-50 w-full max-w-3xl px-4 pointer-events-none">
      <% if notice.present? %>
        <div class="pointer-events-auto bg-emerald-200 border border-emerald-400 text-emerald-600 px-4 py-3 rounded mb-2 shadow">
          <%= notice %>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="pointer-events-auto bg-amber-100 border border-amber-400 text-amber-700 px-4 py-3 rounded shadow">
          <%= alert %>
        </div>
      <% end %>
    </div>

    <div class="">
      <%= yield %>
    </div>
    </div>
  </body>
</html>
