<div data-controller="dropdown" class="relative">
  <% form_field_id = "#{field_name}_select" %>

  <button type="button" data-dropdown-target="button" data-action="click->dropdown#toggle keydown->dropdown#handleKeydown" class="w-full rounded-lg border border-slate-600 bg-slate-700 px-4 py-2.5 text-sm text-slate-100 placeholder-slate-400 transition focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 flex items-center justify-between hover:bg-slate-600">
    <span data-selected-label><%= selected_label %></span>
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </button>

  <div data-dropdown-target="menu" class="hidden absolute top-full left-0 right-0 mt-1 bg-slate-700 border border-slate-600 rounded-lg shadow-xl z-50 max-h-64 overflow-y-auto">
    <% options.each do |option| %>
      <button type="button" data-dropdown-target="option" data-value="<%= option_value.call(option) %>" data-action="click->dropdown#selectOption" class="w-full text-left px-4 py-2.5 text-sm hover:bg-blue-600 hover:text-white text-slate-100 transition flex items-center justify-between">
        <span><%= option_label.call(option) %></span>
      </button>
    <% end %>
  </div>

  <%= hidden_field_tag field_name, selected_value, data: { dropdown_target: "hidden" } %>
</div>
