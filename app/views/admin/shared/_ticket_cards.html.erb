<%# Phone-width card list mirroring the ticket tables (Title / Status / Priority / Category / Created).
    Locals: tickets:, empty_message:, show_solved: (optional) %>
<% show_solved = local_assigns.fetch(:show_solved, false) %>
<ul class="divide-y divide-slate-100 md:hidden">
  <% tickets.each do |ticket| %>
    <li class="p-4">
      <div class="flex items-start justify-between gap-3">
        <%= link_to ticket.title, ticket_path(ticket), class: "min-w-0 break-words font-medium text-slate-900 hover:text-blue-600 hover:underline" %>
        <% if show_solved && ticket.status.to_s.strip.casecmp("closed").zero? %>
          <span class="shrink-0 rounded-full bg-emerald-100 px-2 py-1 text-xs font-semibold text-emerald-700">Solved</span>
        <% end %>
      </div>
      <dl class="mt-2 grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
        <div>
          <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Status</dt>
          <dd class="mt-0.5 text-slate-700"><%= ticket.status %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Priority</dt>
          <dd class="mt-0.5 text-slate-700"><%= ticket.priority %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Category</dt>
          <dd class="mt-0.5 text-slate-700"><%= ticket.category %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Created</dt>
          <dd class="mt-0.5 text-slate-700"><%= ticket.created_at.strftime("%b %d, %Y") %></dd>
        </div>
      </dl>
    </li>
  <% end %>
  <% if tickets.empty? %>
    <li class="p-6 text-center text-sm text-slate-500"><%= empty_message %></li>
  <% end %>
</ul>
