<div class="min-h-screen bg-slate-50 text-slate-900">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 sm:py-12">
    <div class="flex flex-col gap-2">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900">Admin Dashboard</h1>
      <p class="text-slate-600">Overview of users and tickets across the helpdesk.</p>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-2">
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-medium text-slate-500">Total Users</p>
        <p class="mt-2 text-3xl font-bold text-slate-900"><%= @users.length %></p>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-medium text-slate-500">Total Tickets</p>
        <p class="mt-2 text-3xl font-bold text-slate-900"><%= @tickets.length %></p>
      </div>
    </div>

    <section class="mt-12">
      <div class="flex flex-wrap items-center justify-between gap-2">
        <h2 class="text-xl font-semibold text-slate-900">Overview</h2>
        <span class="text-sm text-slate-500">By day of week</span>
      </div>

      <div class="mt-4 grid gap-6 md:grid-cols-2">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="text-sm font-semibold text-slate-700">Tickets by Status</h3>
          <div class="mt-4">
            <%= pie_chart @tickets_by_status, donut: true, height: "260px" %>
          </div>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="text-sm font-semibold text-slate-700">Tickets Reported</h3>
          <div class="mt-4">
            <%= line_chart @tickets_reported, height: "260px", xtitle: "Day of Week", ytitle: "Tickets Reported" %>
          </div>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="text-sm font-semibold text-slate-700">Tickets by Category</h3>
          <div class="mt-4">
            <%= bar_chart @tickets_by_category, height: "260px" %>
          </div>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="text-sm font-semibold text-slate-700">Tickets by Assignee</h3>
          <div class="mt-4">
            <%= bar_chart @tickets_by_assignee, height: "260px" %>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-12">
      <div class="flex flex-wrap items-center justify-between gap-2">
        <h2 class="text-xl font-semibold text-slate-900">Users</h2>
        <div class="flex items-center gap-4">
          <%= link_to "Terminated Users &rarr;".html_safe, admin_terminated_users_path, class: "text-sm font-medium text-blue-600 hover:underline" %>
          <span class="text-sm text-slate-500"><%= @users.length %> records</span>
        </div>
      </div>

      <div class="mt-4 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
        <ul class="divide-y divide-slate-100 md:hidden">
          <% @users.each do |user| %>
            <li class="p-4">
              <div class="flex items-start justify-between gap-3">
                <%= link_to user_display_name(user), admin_user_path(user), class: "min-w-0 wrap-anywhere font-medium text-slate-900 hover:text-blue-600 hover:underline" %>
                <div class="flex shrink-0 flex-wrap justify-end gap-1">
                  <span class="rounded-full bg-slate-100 px-2 py-1 text-xs font-semibold text-slate-600"><%= user.role.capitalize %></span>
                  <% if user.suspended? %>
                    <span class="rounded-full bg-amber-100 px-2 py-1 text-xs font-semibold text-amber-700">Suspended</span>
                  <% end %>
                </div>
              </div>
              <p class="mt-1 truncate text-sm text-slate-600"><%= user_email_display(user) %></p>
              <dl class="mt-2 grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
                <div>
                  <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Job Title</dt>
                  <dd class="mt-0.5 text-slate-700 break-words"><%= user.job_title %></dd>
                </div>
                <div>
                  <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Sector</dt>
                  <dd class="mt-0.5 text-slate-700 break-words"><%= user.sector %></dd>
                </div>
                <div>
                  <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Created</dt>
                  <dd class="mt-0.5 text-slate-700"><%= user.created_at.strftime("%b %d, %Y") %></dd>
                </div>
              </dl>
            </li>
          <% end %>
          <% if @users.empty? %>
            <li class="p-6 text-center text-sm text-slate-500">No users found.</li>
          <% end %>
        </ul>
        <div class="hidden overflow-x-auto md:block">
          <table class="min-w-full divide-y divide-slate-200 text-sm">
            <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
              <tr>
                <th class="px-4 py-3">Name</th>
                <th class="px-4 py-3">Email</th>
                <th class="px-4 py-3">Role</th>
                <th class="px-4 py-3">Job Title</th>
                <th class="px-4 py-3">Sector</th>
                <th class="px-4 py-3">Created</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% @users.each do |user| %>
                <tr class="hover:bg-slate-50">
                  <td class="px-4 py-3 font-medium">
                    <%= link_to user_display_name(user), admin_user_path(user), class: "text-slate-900 hover:text-blue-600 hover:underline" %>
                  </td>
                  <td class="px-4 py-3 text-slate-600"><%= user_email_display(user) %></td>
                  <td class="px-4 py-3">
                    <span class="rounded-full bg-slate-100 px-2 py-1 text-xs font-semibold text-slate-600">
                      <%= user.role.capitalize %>
                    </span>
                    <% if user.suspended? %>
                      <span class="ml-1 rounded-full bg-amber-100 px-2 py-1 text-xs font-semibold text-amber-700">Suspended</span>
                    <% end %>
                  </td>
                  <td class="px-4 py-3 text-slate-600"><%= user.job_title %></td>
                  <td class="px-4 py-3 text-slate-600"><%= user.sector %></td>
                  <td class="px-4 py-3 text-slate-500"><%= user.created_at.strftime("%b %d, %Y") %></td>
                </tr>
              <% end %>
              <% if @users.empty? %>
                <tr>
                  <td class="px-4 py-6 text-center text-slate-500" colspan="6">No users found.</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="mt-12">
      <div class="flex flex-wrap items-center justify-between gap-2">
        <h2 class="text-xl font-semibold text-slate-900">Tickets</h2>
        <span class="text-sm text-slate-500"><%= @tickets.length %> records</span>
      </div>

      <div class="mt-4 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
        <ul class="divide-y divide-slate-100 md:hidden">
          <% @tickets.each do |ticket| %>
            <li class="p-4">
              <p class="break-words font-medium text-slate-900"><%= ticket.title %></p>
              <dl class="mt-2 grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
                <div>
                  <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Status</dt>
                  <dd class="mt-0.5 text-slate-700"><%= ticket.status %></dd>
                </div>
                <div>
                  <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Priority</dt>
                  <dd class="mt-0.5 text-slate-700"><%= ticket.priority %></dd>
                </div>
                <div>
                  <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Category</dt>
                  <dd class="mt-0.5 text-slate-700"><%= ticket.category %></dd>
                </div>
                <div>
                  <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Created</dt>
                  <dd class="mt-0.5 text-slate-700"><%= ticket.created_at.strftime("%b %d, %Y") %></dd>
                </div>
                <div>
                  <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Submitter</dt>
                  <dd class="mt-0.5 text-slate-700 wrap-anywhere"><%= display_person(@users_by_id[ticket.submitter_id], ticket.submitter_name) %></dd>
                </div>
                <div>
                  <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Assignee</dt>
                  <dd class="mt-0.5 text-slate-700 wrap-anywhere"><%= display_person(@users_by_id[ticket.assigned_to_id], ticket[:assigned_to]) %></dd>
                </div>
              </dl>
            </li>
          <% end %>
          <% if @tickets.empty? %>
            <li class="p-6 text-center text-sm text-slate-500">No tickets found.</li>
          <% end %>
        </ul>
        <div class="hidden overflow-x-auto md:block">
          <table class="min-w-full divide-y divide-slate-200 text-sm">
            <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
              <tr>
                <th class="px-4 py-3">Title</th>
                <th class="px-4 py-3">Status</th>
                <th class="px-4 py-3">Priority</th>
                <th class="px-4 py-3">Category</th>
                <th class="px-4 py-3">Submitter</th>
                <th class="px-4 py-3">Assignee</th>
                <th class="px-4 py-3">Created</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% @tickets.each do |ticket| %>
                <tr class="hover:bg-slate-50">
                  <td class="px-4 py-3 font-medium text-slate-900"><%= ticket.title %></td>
                  <td class="px-4 py-3 text-slate-600"><%= ticket.status %></td>
                  <td class="px-4 py-3 text-slate-600"><%= ticket.priority %></td>
                  <td class="px-4 py-3 text-slate-600"><%= ticket.category %></td>
                  <td class="px-4 py-3 text-slate-600"><%= display_person(@users_by_id[ticket.submitter_id], ticket.submitter_name) %></td>
                  <td class="px-4 py-3 text-slate-600"><%= display_person(@users_by_id[ticket.assigned_to_id], ticket[:assigned_to]) %></td>
                  <td class="px-4 py-3 text-slate-500"><%= ticket.created_at.strftime("%b %d, %Y") %></td>
                </tr>
              <% end %>
              <% if @tickets.empty? %>
                <tr>
                  <td class="px-4 py-6 text-center text-slate-500" colspan="7">No tickets found.</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  </div>
</div>
