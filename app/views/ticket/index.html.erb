<div class="m-10">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl text-slate-100 font-bold">Tickets</h1>
    <%= link_to "Create New Ticket", new_ticket_path, class: "bg-blue-600 text-white px-6 py-2.5 rounded-lg font-semibold shadow-lg shadow-blue-500/30 transition hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <!-- The search and filter form -->
  <% active_filters = params.slice(:search, :status, :priority, :category).values.any?(&:present?) %>
  <details class="mb-6 bg-slate-800 border border-slate-700 rounded-lg overflow-hidden" <%="open" if active_filters %>>
    <summary class="cursor-pointer list-none select-none px-6 py-4 font-semibold text-slate-100 border-slate-700 flex items-center justify-between hover:bg-slate-700/50 transition">
      <span>Search & Filter</span>
      <span class="text-xs text-slate-400"><%= active_filters ? "✓ Active" : "Show" %></span>
    </summary>

    <form method="get" class="p-6">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-3 items-end border-t border-slate-700 pt-4">
        <input type="text" name="search" placeholder="Search by title..." value="<%= params[:search] %>" class="rounded-lg border border-slate-600 bg-slate-700 px-4 py-2.5 text-sm text-slate-100 placeholder-slate-400 transition focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20" />

        <select name="status" class="rounded-lg border border-slate-600 bg-slate-700 px-4 py-2.5 text-sm text-slate-100 transition focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20">
          <option value="">Status</option>
          <% @statuses&.each do |status| %>
            <option value="<%= status %>" <%= "selected" if params[:status] == status %>><%= format_ticket_label(status) %></option>
          <% end %>
        </select>

        <select name="priority" class="rounded-lg border border-slate-600 bg-slate-700 px-4 py-2.5 text-sm text-slate-100 transition focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20">
          <option value="">Priority</option>
          <% @priorities&.each do |priority| %>
            <option value="<%= priority %>" <%= "selected" if params[:priority] == priority %>><%= format_ticket_label(priority) %></option>
          <% end %>
        </select>

        <div class="flex gap-2">
          <button type="submit" class="bg-blue-600 text-white px-4 py-2.5 rounded-lg font-semibold transition hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500">Filter</button>
          <a href="<%= tickets_path %>" class="px-4 py-2.5 rounded-lg border border-slate-600 text-slate-300 font-semibold transition hover:bg-slate-700 hover:border-slate-500">Clear</a>
        </div>
      </div>
    </form>
  </details>

  <!-- The tickets list -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <% @tickets.each do |ticket| %>
      <article class="bg-slate-800 border border-slate-700 border-l-4 <%= ticket_priority_accent_class(ticket.priority) %> rounded-lg p-6 shadow-xl hover:shadow-2xl transition">
        <div class="flex items-start justify-between gap-3 mb-4">
          <h2 class="text-lg font-semibold text-slate-100"><%= ticket.title %></h2>
          <div class="flex gap-2 shrink-0">
            <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold ring-1 ring-inset <%= ticket_priority_badge_class(ticket.priority) %>">
              <%= format_ticket_label(ticket.priority) %>
            </span>
            <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold ring-1 ring-inset <%= ticket_status_badge_class(ticket.status) %>">
              <%= format_ticket_label(ticket.status) %>
            </span>
          </div>
        </div>

        <p class="text-sm text-slate-300 mb-4"><%= ticket.description.presence || "No description provided." %></p>

        <div class="text-xs text-slate-400 space-y-1.5 border-t border-slate-700 pt-4">
          <p><strong class="text-slate-300">Category:</strong> <%= ticket.category.presence || "Not set" %></p>
          <p><strong class="text-slate-300">Submitted By:</strong> <%= ticket.submitter_name.presence || user_display_name(ticket.submitter) || "Unassigned" %></p>
          <p><strong class="text-slate-300">Assigned To:</strong> <%= ticket[:assigned_to].presence || user_display_name(ticket.assignee) || "Unassigned" %></p>
          <p><strong class="text-slate-300">Location:</strong> <%= ticket.location.presence || "Not set" %></p>
        </div>
      </article>
    <% end %>
  </div>

  <!-- Pagination links -->
  <div class="mt-4">
    <%== @pagy.series_nav(anchor_string: 'data-turbo-prefetch="false"') %>
  </div>
</div>