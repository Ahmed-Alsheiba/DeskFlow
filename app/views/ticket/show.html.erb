<div class="m-10">
  <div class="max-w-4xl mx-auto">
    <!-- Back link -->
    <div class="mb-6">
      <%= link_to "← Back to Tickets", tickets_path, class: "text-sm text-slate-400 hover:text-slate-200 transition" %>
    </div>

    <!-- Ticket header -->
    <div class="flex items-start justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-bold text-slate-100 mb-2"><%= @ticket.title %></h1>
        <p class="text-slate-400">Created <%= @ticket.created_at.strftime("%b %d, %Y at %I:%M %p") %></p>
      </div>

      <div class="flex gap-2 shrink-0">
        <span class="inline-flex items-center rounded-full px-3 py-1.5 text-xs font-semibold ring-1 ring-inset <%= ticket_priority_badge_class(@ticket.priority) %>">
          <%= format_ticket_label(@ticket.priority) %>
        </span>
        <span class="inline-flex items-center rounded-full px-3 py-1.5 text-xs font-semibold ring-1 ring-inset <%= ticket_status_badge_class(@ticket.status) %>">
          <%= format_ticket_label(@ticket.status) %>
        </span>
      </div>
    </div>

    <!-- Main content -->
    <div class="grid grid-cols-3 gap-6 mb-8">
      <!-- Ticket details -->
      <div class="col-span-2">
        <section class="bg-slate-800 border border-slate-700 rounded-lg p-6 mb-6">
          <h2 class="text-lg font-semibold text-slate-100 mb-4">Details</h2>

          <div class="space-y-4 text-sm">
            <div>
              <p class="text-slate-400 font-medium">Description</p>
              <p class="text-slate-200 mt-2"><%= @ticket.description.presence || "No description provided." %></p>
            </div>

            <div class="grid grid-cols-2 gap-4 pt-4 border-t border-slate-700">
              <div>
                <p class="text-slate-400 font-medium">Category</p>
                <p class="text-slate-200 mt-1"><%= @ticket.category.presence || "Not set" %></p>
              </div>
              <div>
                <p class="text-slate-400 font-medium">Location</p>
                <p class="text-slate-200 mt-1"><%= @ticket.location.presence || "Not set" %></p>
              </div>
            </div>
          </div>

          <% if can_edit_ticket?(@ticket) || preview_mode? %>
            <div class="mt-6 pt-6 border-t border-slate-700">
              <%= link_to(preview_mode? ? "View Ticket Form (read-only)" : "Edit Ticket", edit_ticket_path(@ticket), class: "text-blue-400 hover:text-blue-300 text-sm font-semibold transition") %>
            </div>
          <% end %>
        </section>

        <!-- Comments section -->
        <section class="bg-slate-800 border border-slate-700 rounded-lg p-6">
          <h2 class="text-lg font-semibold text-slate-100 mb-4">Activity (<%= @comments.count %>)</h2>

          <% if @comments.any? %>
            <div class="space-y-4 mb-6">
              <% @comments.each do |comment| %>
                <div class="bg-slate-700/50 rounded-lg p-4 border border-slate-600">
                  <div class="flex items-start justify-between mb-2">
                    <p class="font-semibold text-slate-200">
                      <%= display_person(comment.author, comment.author_name, fallback: "Unknown User") %>
                    </p>
                    <span class="text-xs text-slate-500"><%= time_ago_in_words(comment.created_at) %> ago</span>
                  </div>
                  <p class="text-slate-300 text-sm"><%= comment.content %></p>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-slate-400 text-sm mb-6">No comments yet.</p>
          <% end %>

          <% if can_comment_ticket?(@ticket) %>
            <div class="border-t border-slate-700 pt-6">
              <h3 class="text-sm font-semibold text-slate-200 mb-3">Add Comment</h3>
              <%= form_with model: [@ticket, @comment] do |f| %>
                <% if @comment.errors.any? %>
                  <div class="mb-4 bg-red-900/20 border border-red-600 text-red-400 px-4 py-3 rounded-lg text-sm">
                    <p class="font-semibold"><%= pluralize(@comment.errors.count, "error") %> prevented this comment from being saved:</p>
                    <ul class="list-disc list-inside mt-2">
                      <% @comment.errors.full_messages.each do |msg| %>
                        <li><%= msg %></li>
                      <% end %>
                    </ul>
                  </div>
                <% end %>

                <%= f.text_area :content, placeholder: "Add a comment...", rows: 4, required: true, minlength: 1, class: "w-full rounded-lg border border-slate-600 bg-slate-700 px-4 py-2.5 text-sm text-slate-100 placeholder-slate-400 transition focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20" %>

                <div class="mt-3 flex gap-2">
                  <%= f.submit "Post Comment", class: "bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-semibold transition hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
                  <button type="reset" class="px-4 py-2 rounded-lg border border-slate-600 text-slate-300 text-sm font-semibold transition hover:bg-slate-700">Cancel</button>
                </div>
              <% end %>
            </div>
          <% end %>
        </section>
      </div>

      <!-- Sidebar -->
      <div>
        <section class="bg-slate-800 border border-slate-700 rounded-lg p-6 sticky top-24">
          <h3 class="text-sm font-semibold text-slate-300 uppercase tracking-wide mb-4">Assignment</h3>

          <div class="space-y-4 text-sm">
            <div>
              <p class="text-slate-400 font-medium">Submitted By</p>
              <p class="text-slate-200 mt-2"><%= display_person(@ticket.submitter, @ticket.submitter_name, fallback: "Unknown") %></p>
            </div>

            <div class="pt-4 border-t border-slate-700">
              <p class="text-slate-400 font-medium mb-2">Assigned To</p>
              <% if @ticket.assignee || @ticket[:assigned_to].present? %>
                <div class="flex items-center justify-between gap-2">
                  <p class="text-slate-200">
                    <%= display_person(@ticket.assignee, @ticket[:assigned_to]) %>
                    <% if @ticket.assignee.nil? %>
                      <span class="text-xs text-slate-500">(former member)</span>
                    <% end %>
                  </p>
                  <% if current_user == @ticket.assignee %>
                    <span class="text-xs bg-blue-600/20 text-blue-300 px-2 py-1 rounded">You</span>
                  <% elsif admin_or_manager? && @ticket.assignee&.suspended? %>
                    <span class="text-xs bg-amber-500/20 text-amber-300 px-2 py-1 rounded">Suspended</span>
                  <% end %>
                </div>
                <% if admin_or_manager? && @ticket.assignee&.suspended? %>
                  <p class="mt-2 text-xs text-amber-400">This assignee is suspended and can't act on the ticket — reassign it if it's time-sensitive.</p>
                  <% if can_edit_ticket?(@ticket) %>
                    <%= link_to "Reassign", edit_ticket_path(@ticket), class: "mt-2 inline-block text-xs font-semibold text-blue-400 hover:text-blue-300 transition" %>
                  <% end %>
                <% end %>
              <% else %>
                <p class="text-slate-400">Unassigned</p>
                <% if can_self_assign_ticket?(@ticket) %>
                  <%= button_to "Claim Ticket", claim_ticket_path(@ticket), method: :patch, class: "mt-3 w-full bg-emerald-600 text-white px-4 py-2.5 rounded-lg text-sm font-semibold transition hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
                <% end %>
              <% end %>
            </div>
          </div>

          <% if can_edit_ticket?(@ticket) && !@ticket.status.to_s.strip.casecmp("closed").zero? %>
            <div class="mt-6 pt-6 border-t border-slate-700">
              <button type="button" class="w-full bg-rose-600 text-white px-4 py-2.5 rounded-lg text-sm font-semibold transition hover:bg-rose-700 focus:outline-none focus:ring-2 focus:ring-rose-500" onclick="document.getElementById('close-ticket-dialog-<%= @ticket.id %>').showModal()">
                Close Ticket
              </button>
            </div>
          <% end %>

          <div class="mt-6 pt-6 border-t border-slate-700">
            <p class="text-slate-400 font-medium mb-2 text-xs uppercase tracking-wide">Status</p>
            <p class="text-slate-200"><%= format_ticket_label(@ticket.status) %></p>
          </div>

          <div class="mt-4">
            <p class="text-slate-400 font-medium mb-2 text-xs uppercase tracking-wide">Category</p>
            <p class="text-slate-200"><%= @ticket.category.presence || "Not set" %></p>
          </div>
        </section>
      </div>
    </div>
  </div>
</div>

<% if can_edit_ticket?(@ticket) && !@ticket.status.to_s.strip.casecmp("closed").zero? %>
  <dialog id="close-ticket-dialog-<%= @ticket.id %>" class="fixed inset-0 m-auto rounded-xl border border-slate-700 bg-slate-800 text-slate-100 w-full max-w-lg p-0 backdrop:bg-slate-900/70">
    <div class="p-6 border-b border-slate-700">
      <h3 class="text-lg font-semibold">Close ticket</h3>
      <p class="text-sm text-slate-400 mt-1">Add a closing report to record how this ticket was resolved.</p>
    </div>
    <div class="p-6">
      <%= form_with url: close_ticket_path(@ticket), method: :patch do |f| %>
        <%= text_area_tag "comment[content]", nil, placeholder: "Add a closing report...", rows: 4, required: true, minlength: 1, class: "w-full rounded-lg border border-slate-600 bg-slate-700 px-4 py-2.5 text-sm text-slate-100 placeholder-slate-400 transition focus:border-rose-500 focus:ring-2 focus:ring-rose-500/20" %>
        <div class="mt-4 flex gap-2">
          <%= f.submit "Close Ticket", class: "bg-rose-600 text-white px-4 py-2 rounded-lg text-sm font-semibold transition hover:bg-rose-700 focus:outline-none focus:ring-2 focus:ring-rose-500" %>
          <button type="button" class="px-4 py-2 rounded-lg border border-slate-600 text-slate-300 text-sm font-semibold transition hover:bg-slate-700" onclick="document.getElementById('close-ticket-dialog-<%= @ticket.id %>').close()">
            Cancel
          </button>
        </div>
      <% end %>
    </div>
  </dialog>
<% end %>
