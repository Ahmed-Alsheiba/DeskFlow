<%= form_with model: @ticket do |f| %>
  <section class="max-w-3xl mx-auto bg-white border border-slate-200 border-l-4 border-l-blue-400 rounded-lg p-6 shadow-sm">
    <h1 class="text-2xl font-bold mb-6 text-slate-900">New Ticket</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
      <div>
        <%= f.label :category, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.select :category, ["Hardware", "Software", "Network", "POS", "PMS", "Other"], class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900" %>
      </div>

      <div>
        <%= f.label :priority, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.select :priority, ["Low", "Medium", "High"], class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900" %>
      </div>

      <div>
        <%= f.label :status, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.select :status, ["Open", "In Progress", "Closed"], class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900" %>
      </div>

      <div>
        <%= f.label :location, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :location, class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900" %>
      </div>
    </div>

    <div class="mb-4">
      <%= f.label :title, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_field :title, class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900" %>
    </div>

    <div class="mb-4">
      <%= f.label :description, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_area :description, rows: 4, class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900" %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
      <div>
        <p class="block text-sm font-medium text-slate-700 mb-1">Submitted By</p>
        <div class="w-full rounded-md border border-slate-300 bg-slate-50 px-3 py-2 text-sm text-slate-700">
          <%= user_display_name(current_user) %>
        </div>
      </div>

      <div>
        <%= f.label :assigned_to_id, "Assign To", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.collection_select :assigned_to_id, @users, :id, :display_name, { prompt: "Unassigned" }, class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900" %>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <%= f.submit "Create Ticket", class: "bg-blue-500 text-white px-4 py-2 rounded" %>
      <%= link_to "Back to Tickets", tickets_path, class: "px-4 py-2 rounded border border-slate-300 text-slate-700" %>
    </div>
  </section>
<% end %>
