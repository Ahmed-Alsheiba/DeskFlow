#!/usr/bin/env ruby
# frozen_string_literal: true

# Fetches one secret from Rails encrypted credentials for .kamal/secrets
# command substitution, without booting the Rails app.
#
#   Usage: bin/kamal-secret <dot.separated.key>     e.g. kamal.registry_password
#
# Success: value on stdout, no trailing newline.
# Failure: sentinel on stdout (an empty secret must never deploy silently),
# loud banner on stderr, exit 1. Kamal captures stdout and IGNORES the exit
# status of $(...) substitutions, so the sentinel + stderr are the alarm.

SENTINEL = "KAMAL-SECRET-LOOKUP-FAILED"

def fail_loudly(message)
  $stderr.puts "!" * 72
  $stderr.puts "bin/kamal-secret ERROR: #{message}"
  $stderr.puts "!" * 72
  $stdout.write(SENTINEL)
  exit 1
end

app_root = File.expand_path("..", __dir__)
ENV["BUNDLE_GEMFILE"] = File.join(app_root, "Gemfile")

require "bundler/setup"
require "active_support"
require "active_support/encrypted_configuration"

key_path = ARGV[0].to_s
fail_loudly("usage: bin/kamal-secret <dot.separated.key>") if key_path.empty?

begin
  value = ActiveSupport::EncryptedConfiguration.new(
    config_path: File.join(app_root, "config/credentials.yml.enc"),
    key_path: File.join(app_root, "config/master.key"),
    env_key: "RAILS_MASTER_KEY",
    raise_if_missing_key: true
  ).config.dig(*key_path.split(".").map(&:to_sym))
rescue StandardError => e
  fail_loudly("#{e.class}: #{e.message}")
end

fail_loudly("credential '#{key_path}' not found in config/credentials.yml.enc") if value.nil?
fail_loudly("credential '#{key_path}' is a namespace, not a value") if value.is_a?(Hash)

value = value.to_s
fail_loudly("credential '#{key_path}' is empty") if value.empty?
fail_loudly("credential '#{key_path}' contains a newline") if value.include?("\n")

$stdout.write(value)
